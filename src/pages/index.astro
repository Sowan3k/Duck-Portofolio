---
/**
 * index.astro - the standard view (law 5: ships first, the SEO/no-JS surface,
 * a complete portfolio a recruiter can use without ever seeing the office),
 * with the office island (Phase 3) mounted over it. With JS the office covers
 * the page (entry → CRT → gray-box office); without JS the overlay is hidden
 * (`.no-js`) and the standard view is the whole experience.
 */
import Base from '../layouts/Base.astro';
import Hero from '../components/standard/Hero.astro';
import About from '../components/standard/About.astro';
import Experience from '../components/standard/Experience.astro';
import Projects from '../components/standard/Projects.astro';
import Skills from '../components/standard/Skills.astro';
import Awards from '../components/standard/Awards.astro';
import Education from '../components/standard/Education.astro';
import Roadmap from '../components/standard/Roadmap.astro';
import Contact from '../components/standard/Contact.astro';
import Footer from '../components/standard/Footer.astro';
import Office from '../components/office/Office.tsx';
---

<Base>
  {/* The entry portrait is the LCP (server-rendered, covers the fetch) - preload
      it so it paints as early as possible. */}
  <link
    slot="head"
    rel="preload"
    as="image"
    href="/assets/entry/entry-portrait-sowan--v04-400w.avif"
    type="image/avif"
    fetchpriority="high"
  />

  {/* The standard view - made inert by the island while the office is open. */}
  <div id="standard-view">
    <a class="skip-link" href="#main">Skip to content</a>
    <Hero />
    <main id="main" tabindex="-1">
      <About />
      <Experience />
      <Projects />
      <Skills />
      <Awards />
      <Education />
      <Roadmap />
      <Contact />
    </main>
    <Footer />
  </div>

  {/* The office. client:idle so React hydrates AFTER first paint - the
      server-rendered entry portrait (the LCP) isn't blocked by React's render
      work. No-JS still shows the standard view (overlay hidden via noscript). */}
  <Office client:idle />

  {/* Warm cursor glow - static pages only; pauses itself while the office
      overlay is up (owner decision 2026-07-21). */}
  <script>
    import '../scripts/warm-cursor';
  </script>
</Base>
