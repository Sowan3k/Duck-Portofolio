---
/**
 * Section.astro - a semantic <section> with an accessible heading, used by
 * every standard-view block so landmarks and anchors stay consistent.
 */
interface Props {
  id: string;
  title: string;
  /** Optional small eyebrow line above the heading. */
  eyebrow?: string;
  class?: string;
}

const { id, title, eyebrow, class: className } = Astro.props;
const headingId = `${id}-heading`;
---

<section
  id={id}
  aria-labelledby={headingId}
  class:list={['py-14 sm:py-20', className]}
>
  <div class="mx-auto max-w-4xl px-6">
    {
      eyebrow && (
        <p class="font-sans text-sm font-semibold tracking-wide text-wood-dark uppercase">
          {eyebrow}
        </p>
      )
    }
    <h2 class="font-display text-3xl sm:text-4xl text-green">{title}</h2>
    <div class="mt-2 h-1 w-16 rounded-full bg-mustard" aria-hidden="true"></div>
    <div class="mt-6">
      <slot />
    </div>
  </div>
</section>
