---
/**
 * ContactLinks.astro - the three published channels (email, GitHub, LinkedIn),
 * rendered from profile.contact. Icons are decorative (aria-hidden); the visible
 * text is the accessible name. No phone number is ever present (CV decision).
 */
import { profile } from '../../content/profile';

interface Props {
  class?: string;
}
const { class: className } = Astro.props;

// Minimal inline glyphs, keyed by contact kind.
const icons: Record<string, string> = {
  email:
    'M3 5.5h18a1 1 0 0 1 1 1v11a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1v-11a1 1 0 0 1 1-1Zm.4 1.6 8.6 6 8.6-6',
  github:
    'M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.1-1.47-1.1-1.47-.9-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.9 1.53 2.36 1.09 2.94.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02a9.6 9.6 0 0 1 5 0c1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.68-4.57 4.93.36.31.68.92.68 1.85v2.74c0 .27.18.58.69.48A10 10 0 0 0 12 2Z',
  linkedin:
    'M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5ZM3 9h4v12H3V9Zm7 0h3.8v1.71h.05c.53-.95 1.83-1.96 3.77-1.96 4.03 0 4.78 2.5 4.78 5.76V21h-4v-5.55c0-1.32-.02-3.02-1.9-3.02-1.9 0-2.2 1.44-2.2 2.92V21h-4V9Z',
};
---

<ul class:list={['flex flex-wrap gap-3 list-none p-0 m-0', className]}>
  {
    profile.contact.map((c) => (
      <li>
        <a href={c.href} class="btn btn--ghost" rel={c.kind === 'email' ? undefined : 'me noopener'}>
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill={c.kind === 'email' ? 'none' : 'currentColor'}
            stroke={c.kind === 'email' ? 'currentColor' : 'none'}
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d={icons[c.kind]} />
          </svg>
          <span>{c.label}</span>
        </a>
      </li>
    ))
  }
</ul>
