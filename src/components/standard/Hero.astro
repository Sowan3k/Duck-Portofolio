---
/**
 * Hero.astro — the top of the standard view. Carries the LCP image (the cartoon
 * portrait inner crop, eager + high priority), name, headline, the Swan nod, and
 * the résumé CTA so a recruiter reaches the PDF immediately (law 2).
 */
import { profile } from '../../content/profile';
import Picture from './Picture.astro';
import ContactLinks from './ContactLinks.astro';
---

<header class="border-b border-wood/40 bg-cream">
  <div
    class="mx-auto flex max-w-4xl flex-col-reverse items-center gap-8 px-6 py-14 sm:py-20 md:flex-row md:items-center md:gap-12"
  >
    <div class="w-full md:flex-1">
      <p class="font-sans text-sm font-semibold uppercase tracking-wide text-wood-dark">
        {profile.headline}
      </p>
      <h1 class="font-display text-4xl leading-tight text-ink sm:text-5xl">
        {profile.name}
      </h1>
      <!-- The origin joke is the brand (bible §3) — flavor, not a fact claim. -->
      <p class="mt-3 max-w-prose font-display text-2xl text-green">
        People keep calling me “Swan.” I decided to embrace it. <span aria-hidden="true">🦆</span>
      </p>

      <dl class="mt-5 flex flex-wrap gap-x-6 gap-y-1 font-sans text-sm text-wood-dark">
        <div class="flex gap-1">
          <dt class="sr-only">Location</dt>
          <dd><span aria-hidden="true">📍</span> {profile.location}</dd>
        </div>
        <div class="flex gap-1">
          <dt class="sr-only">Status</dt>
          <dd><span aria-hidden="true">🎓</span> {profile.status}</dd>
        </div>
      </dl>

      <div class="mt-6 flex flex-wrap items-center gap-3">
        <!-- Résumé: plain download, no gate ever (law 2). -->
        <a class="btn btn--primary" href="/resume.pdf" download>
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M12 3v12m0 0 4-4m-4 4-4-4M4 17v2a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-2" />
          </svg>
          Download résumé (PDF)
        </a>
        {/* Enter the interactive office — only useful with JS (law 5). */}
        <button type="button" class="btn btn--ghost enter-office" data-open-office>
          <span aria-hidden="true">🦆</span>
          Visit Swan's Office
        </button>
      </div>

      <ContactLinks class="mt-4" />
    </div>

    <div class="w-40 shrink-0 sm:w-52 md:w-64">
      <div class="overflow-hidden rounded-2xl border-4 border-wood-dark bg-duck shadow-lg">
        <Picture
          stem="entry-portrait-sowan--v04-inner"
          alt={`Cartoon portrait of ${profile.name}.`}
          dir="/assets/portrait"
          widths={[320, 640, 1200]}
          sizes="(max-width: 640px) 10rem, (max-width: 768px) 13rem, 16rem"
          width={1200}
          height={1500}
          loading="eager"
          fetchpriority="high"
          class="block h-auto w-full"
        />
      </div>
    </div>
  </div>
</header>
