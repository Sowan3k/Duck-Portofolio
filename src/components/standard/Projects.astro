---
/**
 * Projects.astro — the four featured projects (profile.ts order). Non-confidential
 * projects show their approved media; Virtual Zara is described only, with a
 * confidentiality callout and NO screenshots or interface (owner decision, law 4).
 * Grab is surfaced as a GitHub link below, not as a featured entry.
 */
import { profile } from '../../content/profile';
import Section from './Section.astro';
import Picture from './Picture.astro';

const awardById = new Map(profile.awards.map((a) => [a.id, a]));
---

<Section id="projects" title="Projects" eyebrow="What I've built">
  <div class="space-y-10">
    {
      profile.projects.map((project) => {
        const award = project.awardId ? awardById.get(project.awardId) : undefined;
        return (
          <article class="card">
            <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
              <h3 class="font-display text-2xl text-ink">{project.name}</h3>
              <span class="badge">{project.status}</span>
              {award && (
                <span class="badge badge--muted">🏅 {award.title}, {award.event.split(' (')[0]}</span>
              )}
            </div>
            <p class="mt-1 font-sans text-sm font-semibold text-wood-dark">
              {project.tagline}
            </p>

            {project.media.length > 0 && (
              <div class="mt-4 grid gap-3 sm:grid-cols-2">
                {project.media.map((m) => (
                  <div class="overflow-hidden rounded-lg border border-wood">
                    <Picture
                      stem={m.stem}
                      alt={m.alt}
                      widths={[360, 720, 1440]}
                      sizes="(max-width: 640px) 90vw, 400px"
                      width={m.width}
                      height={m.height}
                      class="block h-auto w-full"
                    />
                  </div>
                ))}
              </div>
            )}

            {project.confidential && (
              <p class="mt-4 rounded-lg border border-wood bg-cream px-4 py-3 font-sans text-sm text-ink">
                🔒 {project.note}
              </p>
            )}

            <p class="mt-4 max-w-prose font-sans text-base text-ink">
              {project.summary}
            </p>

            <ul class="mt-3 space-y-2 font-sans text-base text-ink">
              {project.bullets.map((b) => (
                <li class="flex gap-2">
                  <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-green" aria-hidden="true" />
                  <span>{b}</span>
                </li>
              ))}
            </ul>

            <div class="mt-4 flex flex-wrap gap-2" aria-label={`${project.name} technologies`}>
              {project.stack.map((tech) => (
                <span class="chip">{tech}</span>
              ))}
            </div>

            {project.links.length > 0 && (
              <div class="mt-5 flex flex-wrap gap-3">
                {project.links.map((link) => (
                  <a
                    class:list={['btn', link.kind === 'demo' ? 'btn--primary' : 'btn--ghost']}
                    href={link.href}
                    rel="noopener"
                    target="_blank"
                  >
                    {link.label}
                    <span class="sr-only"> (opens in a new tab)</span>
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M7 17 17 7M9 7h8v8" />
                    </svg>
                  </a>
                ))}
              </div>
            )}
          </article>
        );
      })
    }
  </div>

  {
    profile.additionalProjects.length > 0 && (
      <p class="mt-8 font-sans text-base text-wood-dark">
        More on GitHub —{' '}
        {profile.additionalProjects.map((p, i) => (
          <>
            {i > 0 && ', '}
            <a class="prose-link" href={p.href} rel="noopener" target="_blank">
              {p.name}
            </a>
          </>
        ))}
        .
      </p>
    )
  }
</Section>
