---
/**
 * Contact.astro - the three published channels + the résumé download again, so
 * the PDF is reachable from the bottom of the page too. Closing line echoes the
 * duck's contact voice (bible §10).
 */
import Section from './Section.astro';
import ContactLinks from './ContactLinks.astro';
---

<Section id="contact" title="Contact" eyebrow="Let's talk">
  <p class="max-w-prose font-display text-2xl text-green">
    If you think we'd build something interesting together…
  </p>

  <ContactLinks class="mt-5" />

  <div class="mt-5">
    <a class="btn btn--primary" href="/resume.pdf" download>
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M12 3v12m0 0 4-4m-4 4-4-4M4 17v2a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-2" />
      </svg>
      Download résumé (PDF)
    </a>
  </div>
</Section>
