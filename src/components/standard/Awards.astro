---
/**
 * Awards.astro - the PIXEL Silver award, rendered from profile.awards as DOM
 * text (law 3). The real numbers (249 students, evaluated by 30 people) come
 * from the CV.
 */
import { profile } from '../../content/profile';
import Section from './Section.astro';
---

<Section id="awards" title="Awards" eyebrow="Still chasing gold">
  <ul class="space-y-6 list-none p-0">
    {
      profile.awards.map((award) => (
        <li class="card flex gap-4">
          <span class="text-3xl" aria-hidden="true">🏅</span>
          <div>
            <h3 class="font-sans text-lg font-bold text-ink">
              {award.title} - {award.event}
            </h3>
            <p class="mt-1 font-sans text-base text-ink">{award.detail}</p>
            <ul class="mt-2 flex flex-wrap gap-2 list-none p-0">
              {award.facts.map((fact) => (
                <li class="chip">{fact}</li>
              ))}
            </ul>
          </div>
        </li>
      ))
    }
  </ul>
</Section>
