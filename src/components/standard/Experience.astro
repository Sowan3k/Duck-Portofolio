---
/**
 * Experience.astro - roles with impact bullets. The ECTrons entry prints the
 * mandatory ESS context line under the (unchanged) title; Museum Hotel keeps
 * its part-time label (CV rules, enforced in profile.ts + tests).
 */
import { profile } from '../../content/profile';
import Section from './Section.astro';
---

<Section id="experience" title="Experience" eyebrow="Where I've worked">
  <ol class="space-y-8 list-none p-0">
    {
      profile.experience.map((job) => (
        <li class="card">
          <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
            <h3 class="font-sans text-lg font-bold text-ink">
              {job.role}
              {job.employmentType === 'part-time' && (
                <span class="badge badge--muted ml-2 align-middle">Part-time</span>
              )}
            </h3>
            <p class="font-sans text-sm text-wood-dark">{job.period}</p>
          </div>

          <p class="mt-1 font-sans text-base font-semibold text-wood-dark">
            {job.organization} · {job.location}
          </p>

          {job.context && (
            <p class="mt-2 max-w-prose font-sans text-sm italic text-ink">
              {job.context}
            </p>
          )}

          <ul class="mt-3 space-y-2 font-sans text-base text-ink">
            {job.bullets.map((b) => (
              <li class="flex gap-2">
                <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-green" aria-hidden="true" />
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </li>
      ))
    }
  </ol>
</Section>
