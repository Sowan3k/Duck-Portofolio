---
/**
 * Education.astro - USM degree with an unmistakable completion status. The
 * PIXEL award is deliberately NOT repeated here (CV rule; enforced in tests).
 */
import { profile } from '../../content/profile';
import Section from './Section.astro';
---

<Section id="education" title="Education" eyebrow="Where I studied">
  <ul class="space-y-6 list-none p-0">
    {
      profile.education.map((edu) => (
        <li class="card">
          <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
            <h3 class="font-sans text-lg font-bold text-ink">{edu.degree}</h3>
            <p class="font-sans text-sm text-wood-dark">{edu.period}</p>
          </div>
          <p class="mt-1 font-sans text-base font-semibold text-wood-dark">
            {edu.institution} · {edu.location}
          </p>
          <p class="mt-2 font-sans text-base text-ink">{edu.status}</p>
          {edu.finalYearProject && (
            <p class="mt-2 font-sans text-sm text-ink">
              <span class="font-semibold">Final Year Project:</span>{' '}
              {edu.finalYearProject}
              {edu.supervisor && <> · Supervisor: {edu.supervisor}</>}
              {edu.examiner && <> · Examiner: {edu.examiner}</>}
            </p>
          )}
        </li>
      ))
    }
  </ul>
</Section>
